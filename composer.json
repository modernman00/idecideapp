{
  "name": "idecide/idecide",
  "description": "iDecide - Decision Support Platform",
  "authors": [
    {
      "name": "Olawale Olaogun",
      "email": "modernman00@yahoo.com"
    }
  ],
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/modernman00/shared-lib"
    }
  ],
  "require": {
    "php": "^8.2",
    "twig/twig": "^3.14.1",
    "altorouter/altorouter": "^2.0",
    "vlucas/phpdotenv": "^5.5",
    "eftec/bladeone": "^4.18",
    "filp/whoops": "^2.18",
    "maestroerror/php-heic-to-jpg": "^1.0",
    "phpmailer/phpmailer": "^6.5",
    "monolog/monolog": "^3.9",
    "guzzlehttp/guzzle": "^7.9",
    "symfony/mailer": "^7.3",
    "modernman00/shared-lib": "^1.8.23",
    "league/oauth2-google": "^5.0"
  },
  "config": {
    "optimize-autoloader": true,
    "allow-plugins": {
      "kylekatarnls/update-helper": true
    },
    "platform": {
      "php": "8.2"
    },
    "process-timeout": 0,
    "disable-tls": false
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "squizlabs/php_codesniffer": "^3.13",
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.84"
  }
}
