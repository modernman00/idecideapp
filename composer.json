{
  "name": "idecide/idecide",
  "description": "iDecide - Decision Support Platform",
  "authors": [
    {
      "name": "Olawale Olaogun",
      "email": "modernman00@yahoo.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    },
    "files": [
      "app/function/helper.php",
      "app/function/laravelHelper.php",
      "app/function/date.php"
    ]
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/modernman00/shared-lib"
    }
  ],
  "require": {
    "php": "^8.2",
    "twig/twig": "^3.14.1",
    "altorouter/altorouter": "^1.2",
    "vlucas/phpdotenv": "^5.5",
    "eftec/bladeone": "^4.18",
    "waleolaogun/shared-lib": "^1.5.8",
    "filp/whoops": "^2.18",
     "cloudmersive/cloudmersive_virusscan_api_client": "^3.1",
    "spatie/image-optimizer": "^1.6",
    "intervention/image": "^3.11",
    "maestroerror/php-heic-to-jpg": "^1.0",
    "phpmailer/phpmailer": "^6.5"
  },
  "config": {
    "optimize-autoloader": true,
    "allow-plugins": {
      "kylekatarnls/update-helper": true
    },
    "platform": {
      "php": "8.2"
    },
    "process-timeout": 0,
    "disable-tls": false
  }
}
