{
  "name": "idecide",
  "version": "1.0.0",
  "description": "iDecide - Decision Support Platform",
  "main": "index",
  "typings": "index",
  "scripts": {
    "dev": "npm run development",
    "development": "mix",
    "watch": "mix watch",
    "watch-poll": "mix watch -- --watch-options-poll=1000",
    "hot": "mix watch --hot",
    "prod": "npm run production",
    "production": "mix --production",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint resources/assets/js/ --ext .js",
    "lint:fix": "eslint resources/assets/js/ --ext .js --fix",
    "quality:php": "vendor/bin/phpcs -d memory_limit=1G",
    "quality:php:fix": "vendor/bin/phpcbf -d memory_limit=1G",
    "test:php": "vendor/bin/phpunit",
    "test:all": "npm run test && npm run test:php",
    "quality:all": "npm run lint && npm run quality:php"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/modernman00/idecide.git"
  },
  "author": "wale olaogun",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/modernman00/idecide/issues"
  },
  "homepage": "https://github.com/modernman00/idecide#readme",
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "babel-jest": "^29.7.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.31.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.0.5",
    "laravel-mix": "^6.0.49",
    "resolve-url-loader": "^3.1.0",
    "sass-loader": "^8.0.0",
    "webpack": "^5.100.2"
  },
  "dependencies": {
    "@modernman00/shared-js-lib": "^1.2.7",
    "axios": "^1.10.0",
    "canvas-confetti": "^1.9.3",
    "chart.js": "^4.5.0",
    "jquery": "^3.7.1",
    "npm": "^11.4.2",
    "sass": "^1.89.2",
    "svg-gauge": "^1.0.7"
  }
}
